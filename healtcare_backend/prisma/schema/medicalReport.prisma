model MedicalReport {
  id         String   @id @default(uuid(7))
  reportName String
  reportLink String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId], map: "idx_medical_report_patientId")
  @@map("medical_reports")
}
