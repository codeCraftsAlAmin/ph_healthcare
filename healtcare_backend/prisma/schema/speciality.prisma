model Speciality {
  id                 String             @id @default(uuid(7))
  title              String             @unique @db.VarChar(100)
  icon               String?            @db.VarChar(255)
  description        String?
  isDeleted          Boolean            @default(false)
  deletedAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  doctorSpecialities DoctorSpeciality[]

  @@index([isDeleted], map: "idx_speciality_isDeleted")
  @@index([title], map: "idx_speciality_title")
  @@map("specialities")
}

model DoctorSpeciality {
  id           String     @id @default(uuid(7))
  specialityId String
  doctorId     String
  doctor       Doctor     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  speciality   Speciality @relation(fields: [specialityId], references: [id], onDelete: Cascade)

  @@unique([doctorId, specialityId])
  @@index([doctorId], map: "idx_doctor_speciality_doctorId")
  @@index([specialityId], map: "idx_doctor_speciality_speciality_id")
  @@map("doctor_specialities")
}
