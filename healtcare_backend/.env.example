NODE_ENV=development
PORT=5000

# postgres url
DATABASE_URL=postgres://username:password@hostname:5432/dbname?sslmode=require

# better auth url
BETTER_AUTH_SECRET=your_auth_secret_here
BETTER_AUTH_URL=http://localhost:5000

# jwt token
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d

# nodemailer
EMAIL_SENDER_SMTP_USER=your_email@example.com
EMAIL_SENDER_SMTP_FROM=your_email@example.com
EMAIL_SENDER_SMTP_PORT=587
EMAIL_SENDER_SMTP_PASS=your_email_password
EMAIL_SENDER_SMTP_HOST=smtp.gmail.com

# google cloude
GOOGLE_CLOUDE_CLIENT_ID=your_google_client_id
GOOGLE_CLOUDE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/callback/google

# fronted url
FRONTEND_URL=http://localhost:3000

# cloudinary
CLOUDINARY_KEY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret